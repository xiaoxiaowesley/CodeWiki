# =============================================================================
# CodeWiki — Environment Configuration
# Copy this to .env and customize as needed
# =============================================================================

# --- Wiki Output ---

# Wiki output path (relative to code repo root, default: ./wiki)
# The code repo path is NOT configured here — pass it as a skill parameter (defaults to CWD)
CODE_WIKI_OUTPUT_PATH=./wiki

# --- Wiki Structure ---

# Path to wiki structure config (default: uses built-in schema/wiki-structure.yaml)
CODE_WIKI_STRUCTURE_CONFIG=

# Internal link format: wikilink | markdown
CODE_WIKI_LINK_FORMAT=wikilink

# Max pages to create/update per ingest operation
CODE_WIKI_MAX_PAGES_PER_INGEST=20

# Lint schedule: manual
LINT_SCHEDULE=manual

# --- QMD Semantic Search (optional) ---
#
# QMD indexes wiki pages and source code for semantic-level search.
# Without QMD: all skills fall back to Grep/Glob — fully functional, just slower.
# With QMD: semantic search enables concept-level matches across wiki and code.

# Name of the QMD collection indexing compiled wiki pages
QMD_WIKI_COLLECTION=

# Name of the QMD collection indexing source code files
QMD_CODE_COLLECTION=

# QMD integration transport: mcp | cli
QMD_TRANSPORT=mcp

# CLI search quality mode: quality | balanced | fast
QMD_CLI_SEARCH_MODE=quality

# Optional qmd binary override if qmd is not on PATH
QMD_CLI=qmd
